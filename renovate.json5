{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [],
    "commitMessagePrefix": "Renovate:",
    "schedule": [],
    "timezone": "Europe/Berlin",
    "prConcurrentLimit": 1,
    "ignorePaths": [],
    "ignoreDeps": [
        "@types/node", // We want to control when we upgrade node versions (and types)
    ],
    "packageRules": [
        {
            "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
            "allowedVersions": "<=18"
        },
        {
            // react-intl 8 requires react 19
            "matchPackageNames": ["react-intl"],
            "allowedVersions": "<=7"
        }
    ]
}
